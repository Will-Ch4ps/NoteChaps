{
  "name": "notechaps",
  "version": "1.0.0",
  "description": "Modern WYSIWYG Markdown desktop editor",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "icons:generate": "py -3 build/generate_icon.py"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "electron-store": "^8.2.0",
    "mammoth": "^1.7.2",
    "mermaid": "^11.14.0",
    "prosemirror-commands": "^1.5.2",
    "prosemirror-dropcursor": "^1.8.1",
    "prosemirror-gapcursor": "^1.3.2",
    "prosemirror-history": "^1.4.0",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-markdown": "^1.13.0",
    "prosemirror-model": "^1.22.3",
    "prosemirror-schema-list": "^1.4.0",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.9.0",
    "prosemirror-view": "^1.34.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.notechaps.app",
    "productName": "NoteChaps",
    "directories": {
      "output": "release"
    },
    "files": [
      "out",
      "dist"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "build",
        "filter": ["icon.ico", "icon.png"]
      }
    ],
    "icon": "build/icon.ico",
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Editor"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NoteChaps"
    }
  }
}
